# ── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Bybit ───────────────────────────────────────────────────
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret
BYBIT_TESTNET=true

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=coinuser
POSTGRES_PASSWORD=coinpassword
POSTGRES_DB=coin_assistant
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://coinuser:coinpassword@db:5432/coin_assistant
DATABASE_SYNC_URL=postgresql://coinuser:coinpassword@db:5432/coin_assistant

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_POST_NEW=post.new

# ── Application ──────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ── Finnhub ──────────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_api_key

# ── YouTube crawler ──────────────────────────────────────────
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxx
YOUTUBE_SESSION_COOKIE=your_session_cookie_value
CRAWL_INTERVAL_SECONDS=60
